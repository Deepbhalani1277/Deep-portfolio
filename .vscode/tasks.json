{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Next.js Dev Server",
			"type": "shell",
			"command": "pnpm",
			"args": [
				"run",
				"dev"
			],
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Run Next.js Dev Server via Corepack",
			"type": "shell",
			"command": "corepack",
			"args": [
				"pnpm",
				"run",
				"dev"
			],
			"isBackground": true,
			"group": "build"
		}
	]
}